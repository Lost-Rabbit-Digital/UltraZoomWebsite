---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Ultra Zoom | Hover-to-Zoom for 70+ Websites"
  description="Instant hover-to-zoom for images across 70+ websites. Free browser extension for Chrome and Firefox."
  og={{
    url: 'https://ultrazoom.app/',
    title: 'Ultra Zoom | Hover-to-Zoom for 70+ Websites',
    description: 'Instant hover-to-zoom for images across 70+ websites. Free browser extension for Chrome and Firefox.',
    image: 'https://ultrazoom.app/images/icon-128.png',
  }}
>
    <main class="landing" id="main-content">
        <section class="landing-hero">
            <img src="/images/icon-128.png" alt="" class="landing-logo" width="128" height="128">
            <h1 class="landing-title">Ultra Zoom</h1>
            <p class="landing-tagline">Instant hover-to-zoom for images across <strong>70+ websites</strong>.</p>

            <ul class="install-links landing-install">
                <li>
                    <a href="https://chromewebstore.google.com/detail/ultra-zoom/jalclpdejbeamaamcpbolkclpnleagmg" class="install-button chrome" target="_blank" rel="noopener">
                        <svg class="install-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true" focusable="false">
                            <path d="M12 0C8.21 0 4.831 1.757 2.632 4.501l3.953 6.848A5.454 5.454 0 0 1 12 6.545h10.691A12 12 0 0 0 12 0zM1.931 5.47A11.943 11.943 0 0 0 0 12c0 6.012 4.42 10.991 10.189 11.864l3.953-6.847a5.45 5.45 0 0 1-6.865-2.29zm13.342 2.166a5.446 5.446 0 0 1 1.45 7.09l.002.001-3.953 6.848c.313.03.63.047.951.047 6.627 0 12-5.373 12-12 0-1.034-.135-2.035-.377-2.986zM12 8.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7z"/>
                        </svg>
                        Install for Chrome
                    </a>
                </li>
                <li>
                    <a href="https://addons.mozilla.org/en-US/firefox/addon/ultra-zoom/" class="install-button firefox" target="_blank" rel="noopener">
                        <svg class="install-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true" focusable="false">
                            <path d="M22.207 5.534a11.18 11.18 0 0 0-2.455-3.218c.472.869.744 1.79.864 2.352a9.597 9.597 0 0 0-3.678-3.533c-2.057-1.17-4.228-1.32-5.2-1.238a9.747 9.747 0 0 0-5.393 2.138c-.346.3-1.178 1.095-1.884 2.268-.58 1.024-.876 1.963-1.034 2.608a10.783 10.783 0 0 1 2.873-3.312c3.617-2.746 8.239-2.227 8.694-2.174l.03.003c-2.282.103-4.267.8-5.725 1.753A10.143 10.143 0 0 0 6.32 6.8 8.505 8.505 0 0 0 4.25 9.87a7.106 7.106 0 0 0-.143 4.093 8.154 8.154 0 0 0 1.446 3.143 8.482 8.482 0 0 0 2.875 2.455A8.91 8.91 0 0 0 12 20.634a8.62 8.62 0 0 0 3.71-.818 8.177 8.177 0 0 0 2.925-2.283 7.775 7.775 0 0 0 1.503-3.2 7.236 7.236 0 0 0-.115-3.582 6.687 6.687 0 0 0-1.57-2.815c.216.407.37.838.467 1.283a5.845 5.845 0 0 1-.453 3.677 6.11 6.11 0 0 1-2.36 2.629A6.47 6.47 0 0 1 12 16.638a6.596 6.596 0 0 1-2.735-.59 6.17 6.17 0 0 1-2.187-1.703 5.763 5.763 0 0 1-1.147-2.421 5.217 5.217 0 0 1 .146-2.8 5.494 5.494 0 0 1 1.39-2.25c.22-.21.461-.406.72-.577a4.58 4.58 0 0 1 1.604-.72A3.764 3.764 0 0 1 12 6a3.72 3.72 0 0 1 2.18.686 3.51 3.51 0 0 1 1.28 1.74c.084.26.13.53.137.802a2.333 2.333 0 0 0-.764-.822A2.23 2.23 0 0 0 13.6 8.06a2.189 2.189 0 0 0-1.625.687 2.226 2.226 0 0 0-.617 1.657c0 .91.554 1.695 1.343 2.033a2.47 2.47 0 0 0 .939.195 2.404 2.404 0 0 0 1.703-.725 2.494 2.494 0 0 0 .697-1.812c0-.044 0-.088-.003-.132.005.002.397 1.04.095 2.324a4.084 4.084 0 0 1-1.286 2.14 4.32 4.32 0 0 1-2.416 1.065 4.476 4.476 0 0 1-2.655-.42 4.207 4.207 0 0 1-1.866-1.735 4.017 4.017 0 0 1-.535-2.458c.055-.855.35-1.67.85-2.35a4.85 4.85 0 0 1 .953-.93c-1.3.41-2.347 1.255-3.015 2.308A5.593 5.593 0 0 0 5.3 13.357a5.53 5.53 0 0 0 .882 3.27 5.834 5.834 0 0 0 2.603 2.178 6.216 6.216 0 0 0 3.353.522 6.022 6.022 0 0 0 3.094-1.298 5.683 5.683 0 0 0 1.829-2.84c.027-.09.049-.182.07-.273l.003.003a8.063 8.063 0 0 0 .319-2.39c-.012-1.043-.225-2.044-.654-2.914a7.14 7.14 0 0 0-3.903-3.6A7.61 7.61 0 0 0 9.39 5.31a7.18 7.18 0 0 0-3.355 1.588A7.034 7.034 0 0 0 3.99 9.91a6.786 6.786 0 0 0-.154 3.598 6.998 6.998 0 0 0 1.562 3.157 7.399 7.399 0 0 0 3.005 2.201A7.813 7.813 0 0 0 12 19.5a7.667 7.667 0 0 0 3.737-.936 7.26 7.26 0 0 0 2.752-2.592 6.885 6.885 0 0 0 1.135-3.545 6.655 6.655 0 0 0-.717-3.374 7.518 7.518 0 0 0-1.14-1.546c.61.16 1.206.443 1.762.854.443.333.852.714 1.237 1.132a9.53 9.53 0 0 1-.062-2.403c.06-.456.15-.898.284-1.322-.42-.42-.887-.817-1.393-1.178-.534-.378-1.098-.698-1.68-.96.007-.037.013-.075.022-.112a6.793 6.793 0 0 0-.028-3.204 11.018 11.018 0 0 1 4.297 4.22z"/>
                        </svg>
                        Install for Firefox
                    </a>
                </li>
            </ul>

            <ul class="hero-proof" aria-label="Highlights">
                <li>
                    <a href="https://chromewebstore.google.com/detail/ultra-zoom/jalclpdejbeamaamcpbolkclpnleagmg" target="_blank" rel="noopener">Read reviews on the Chrome Web Store &rarr;</a>
                </li>
                <li><span class="hero-proof-pill">Manifest V3 native</span></li>
                <li><span class="hero-proof-pill">Zero telemetry</span></li>
                <li><span class="hero-proof-pill"><a href="/whats-new">Updated this month</a></span></li>
            </ul>

            <p class="landing-blurb">
                Hover any image. The full-size version appears instantly. The hover-to-zoom
                extension that doesn&rsquo;t sell your browsing history.
            </p>

            <p class="landing-help-link">
                Need setup help? Visit the <a href="/help">Help page</a> or read the <a href="/blog">blog</a>.
            </p>
        </section>

        <section class="trust-band" aria-label="Why Ultra Zoom">
            <ul class="trust-band-list">
                <li class="trust-band-item">
                    <strong>No tracking.</strong>
                    <span>Zero telemetry, zero analytics, no server that sees your browsing. <a href="/blog/zero-knowledge-architecture">See the architecture</a>.</span>
                </li>
                <li class="trust-band-item">
                    <strong>Works on 70+ sites.</strong>
                    <span>Google Images, Reddit, Twitter/X, Instagram, Amazon, Pinterest, eBay, and dozens more out of the box.</span>
                </li>
                <li class="trust-band-item">
                    <strong>Free forever.</strong>
                    <span>The core extension is free. Pro unlocks power features for people who live in their browser.</span>
                </li>
            </ul>
        </section>

        <section class="screenshot-gallery" aria-label="Ultra Zoom in action">
            <h2 class="gallery-title">See It in Action</h2>
            <div class="gallery-grid">
                <figure class="gallery-item">
                    <img src="/images/ultra_zoom_screen_1.png" alt="Welcome page showing how Ultra Zoom works with step-by-step instructions" width="800" height="600" loading="lazy">
                    <figcaption>Welcome page with quick-start guide</figcaption>
                </figure>
                <figure class="gallery-item">
                    <img src="/images/ultra_zoom_screen_2.png" alt="Settings page with display options like overlay opacity, size, and transition speed" width="800" height="600" loading="lazy">
                    <figcaption>Fine-tune your zoom experience</figcaption>
                </figure>
                <figure class="gallery-item">
                    <img src="/images/ultra_zoom_screen_3.png" alt="Plugins tab showing per-site toggle switches for 70+ websites" width="800" height="600" loading="lazy">
                    <figcaption>Toggle plugins for 70+ sites</figcaption>
                </figure>
                <figure class="gallery-item">
                    <img src="/images/ultra_zoom_screen_4.png" alt="Account tab with Pro upgrade options and pricing tiers" width="800" height="600" loading="lazy">
                    <figcaption>Upgrade to Pro for power features</figcaption>
                </figure>
            </div>
        </section>

        <section class="different-callout" aria-label="Why Ultra Zoom is different">
            <div class="different-callout-inner">
                <h2 class="different-callout-title">Built different, on purpose</h2>
                <p class="different-callout-body">
                    The most popular hover-zoom extension once shipped an update that quietly
                    logged every URL its users visited. Ultra Zoom&rsquo;s architecture makes that
                    scenario structurally impossible. No remote code. No analytics endpoint.
                    No server that could collect the data.
                </p>
                <p class="different-callout-cta">
                    <a href="/blog/hover-zoom-privacy-scandal">Read the story &rarr;</a>
                </p>
            </div>
        </section>

        <section class="support-strip" aria-label="Ultra Zoom Pro">
            <div class="support-strip-inner">
                <p class="support-strip-text">
                    <strong>Go Pro for power browsing.</strong>
                    Video playback controls, advanced gallery, hover-history search, custom URL rules.
                    <a href="/pricing">See Pro features &rarr;</a>
                </p>
                <div class="support-strip-actions">
                    <a href="#" class="payment-btn-hero support-strip-btn" data-plan="monthly">Start 7-day free trial</a>
                    <span class="support-strip-or"><a href="#" data-plan="annual">$29.99/yr</a> &middot; <a href="#" data-plan="lifetime">$59.99 lifetime</a></span>
                </div>
            </div>
            <p id="checkout-error" class="checkout-error" hidden></p>
        </section>

        <section class="referral-strip" aria-label="Refer friends">
            <div class="referral-strip-inner">
                <h2 class="referral-strip-title">Already using Ultra Zoom?</h2>
                <p class="referral-strip-body">
                    Share your link from <em>Settings &rarr; Referrals</em> in the extension popup.
                    Every friend who installs earns you credit toward Pro &mdash; we don&rsquo;t pay influencers, we pay users.
                </p>
            </div>
        </section>
    </main>

    <script is:inline>
        document.querySelectorAll('[data-plan]').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                var plan = btn.getAttribute('data-plan');
                var errEl = document.getElementById('checkout-error');
                if (errEl) { errEl.hidden = true; errEl.textContent = ''; }
                btn.style.opacity = '0.6';
                btn.style.pointerEvents = 'none';

                fetch('https://api.ultrazoom.app/api/checkout', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ plan: plan })
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data.url) {
                        window.location.href = data.url;
                    } else {
                        throw new Error(data.error || 'Unable to start checkout');
                    }
                })
                .catch(function(err) {
                    if (errEl) {
                        errEl.textContent = err.message || 'Something went wrong. Please try again.';
                        errEl.hidden = false;
                    }
                })
                .finally(function() {
                    btn.style.opacity = '';
                    btn.style.pointerEvents = '';
                });
            });
        });
    </script>
</BaseLayout>
