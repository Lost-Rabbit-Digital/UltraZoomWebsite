---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Zoom Score — How zoom-ready is any webpage? | Ultra Zoom"
  description="Paste a product URL and get an instant Zoom Quality Score. We analyze source image resolution, hi-res variants, and detail density. Free, no install required."
  currentPage="zoom-score"
  og={{
    url: 'https://ultrazoom.app/zoom-score',
    title: 'Zoom Score — Grade any webpage\u2019s image quality in seconds',
    description: 'How zoom-friendly is any product page? Paste a URL, get a score in 10 seconds. Free.',
    image: 'https://ultrazoom.app/images/icon-128.png',
  }}
>
  <main class="main zoom-score-page" id="main-content">
    <section class="zs-hero">
      <h1>Zoom Score</h1>
      <p class="zs-sub">
        How zoom-friendly is any webpage? Paste a URL — we check the source image resolution, hi-res variants, and detail density. In 10 seconds.
      </p>

      <form id="zs-form" class="zs-form" novalidate>
        <label for="zs-url" class="zs-label">Product or image page URL</label>
        <div class="zs-input-row">
          <input
            id="zs-url"
            name="url"
            type="url"
            required
            placeholder="https://www.etsy.com/listing/..."
            autocomplete="off"
            spellcheck="false"
            inputmode="url"
          />
          <button type="submit" class="zs-submit">Get score</button>
        </div>
        <p class="zs-note">We fetch the page once and score it. We don’t store your identity. Cached results are anonymous and expire in 30 days. Some marketplaces (Etsy, Amazon) may block our fetch — if so, try a direct image URL.</p>
      </form>

      <div id="zs-status" class="zs-status" hidden></div>
    </section>

    <section class="zs-how">
      <h2>How it works</h2>
      <ol>
        <li><strong>Source resolution (40 pts)</strong> — biggest native image we can reach on the page.</li>
        <li><strong>Hi-res variants (20 pts)</strong> — does the site expose larger crops via srcset or CDN params?</li>
        <li><strong>Image count (15 pts)</strong> — how many distinct product-worthy images are discoverable.</li>
        <li><strong>Pixel density (15 pts)</strong> — pixels per byte — a proxy for compression quality.</li>
        <li><strong>Lazy-load hygiene (10 pts)</strong> — modern formats (WebP/AVIF) and proper loading hints.</li>
      </ol>
      <p>Total maxes at 100. A+ ≥ 95. Letter grade shown next to your score.</p>
    </section>
  </main>
</BaseLayout>

<style>
  .zoom-score-page { max-width: 860px; margin: 0 auto; padding: 48px 24px; }
  .zs-hero h1 { font-size: 42px; margin: 0 0 12px; }
  .zs-sub { font-size: 17px; color: #8b949e; max-width: 620px; margin: 0 0 28px; line-height: 1.55; }
  .zs-form { margin: 0 0 12px; }
  .zs-label {
    display: block; font-size: 13px; font-weight: 600;
    color: #c9d1d9; margin-bottom: 8px;
  }
  .zs-input-row { display: flex; gap: 8px; flex-wrap: wrap; }
  #zs-url {
    flex: 1 1 320px; min-width: 0;
    padding: 12px 14px; font-size: 15px;
    background: #0d1117; color: #e6edf3;
    border: 1px solid #30363d; border-radius: 8px;
  }
  #zs-url:focus {
    outline: none; border-color: #58a6ff;
    box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.2);
  }
  .zs-submit {
    padding: 12px 22px; font-size: 15px; font-weight: 600;
    background: #58a6ff; color: #0d1117;
    border: 0; border-radius: 8px; cursor: pointer;
    transition: background 120ms ease;
  }
  .zs-submit:hover { background: #79b8ff; }
  .zs-submit[disabled] { opacity: 0.5; cursor: not-allowed; }
  .zs-note { font-size: 12px; color: #6e7681; margin: 10px 0 0; }

  .zs-status { margin-top: 16px; padding: 14px 16px; border-radius: 8px; font-size: 14px; }
  .zs-status.info { background: #161b22; border: 1px solid #30363d; color: #c9d1d9; }
  .zs-status.err { background: rgba(248, 81, 73, 0.1); border: 1px solid rgba(248, 81, 73, 0.4); color: #f85149; }

  .zs-how { margin-top: 48px; }
  .zs-how h2 { font-size: 22px; }
  .zs-how ol { color: #c9d1d9; line-height: 1.7; }
</style>

<script is:inline>
  (function () {
    var API = 'https://api.ultrazoom.app';
    var form = document.getElementById('zs-form');
    var input = document.getElementById('zs-url');
    var submit = form && form.querySelector('.zs-submit');
    var status = document.getElementById('zs-status');

    function setStatus(msg, kind) {
      if (!status) return;
      if (!msg) { status.hidden = true; status.textContent = ''; status.className = 'zs-status'; return; }
      status.hidden = false;
      status.textContent = msg;
      status.className = 'zs-status ' + (kind || 'info');
    }

    function gotoReport(id) {
      location.href = '/zoom-score/r/' + encodeURIComponent(id);
    }

    async function submitUrl(urlStr) {
      setStatus('Analyzing\u2026 this usually takes 5\u201315 seconds.', 'info');
      if (submit) submit.disabled = true;
      try {
        let res;
        try {
          res = await fetch(API + '/api/zoom-score', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ url: urlStr }),
          });
        } catch (netErr) {
          throw new Error('Network error \u2014 check your connection and try again.');
        }
        var data = null;
        try { data = await res.json(); } catch (_) { /* non-JSON body, e.g. edge 502 */ }
        if (!res.ok) {
          if (res.status >= 500) {
            throw new Error('Our analyzer is temporarily unavailable. Some marketplaces (Etsy, Amazon) block automated fetches \u2014 try a direct image URL, or retry in a minute.');
          }
          throw new Error((data && data.error) || 'That URL couldn\u2019t be analyzed. Make sure it\u2019s a public product or image page.');
        }
        if (!data || !data.id) {
          throw new Error('Analyzer returned no result id. Please retry.');
        }
        gotoReport(data.id);
      } catch (err) {
        setStatus((err && err.message) || 'Could not score that URL.', 'err');
      } finally {
        if (submit) submit.disabled = false;
      }
    }

    if (form && input) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var v = (input.value || '').trim();
        if (!v) return;
        submitUrl(v);
      });
    }

    // Legacy deep-link: ?r=<id> used to render results inline on this page.
    // Forward those to the dedicated report page so old share links still work.
    var params = new URLSearchParams(location.search);
    var legacyId = params.get('r');
    if (legacyId && /^[a-z0-9]{8,32}$/.test(legacyId)) {
      location.replace('/zoom-score/r/' + encodeURIComponent(legacyId));
      return;
    }

    // Re-analyze shortcut: /zoom-score?url=...&rescore=1 pre-fills and submits.
    var prefill = params.get('url');
    var rescore = params.get('rescore');
    if (prefill && input) {
      input.value = prefill;
      if (rescore) submitUrl(prefill);
    }
  })();
</script>
