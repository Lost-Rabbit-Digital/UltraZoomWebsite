                <li><a href="/images/icon-48.png" target="_blank" rel="noopener">Ultra Zoom logo &mdash; 48px PNG</a></li>
                <li><a href="/images/ultra_zoom_screen_1.png" target="_blank" rel="noopener">Screenshot &mdash; welcome page</a></li>
                <li><a href="/images/ultra_zoom_screen_2.png" target="_blank" rel="noopener">Screenshot &mdash; settings</a></li>
                <li><a href="/images/ultra_zoom_screen_3.png" target="_blank" rel="noopener">Screenshot &mdash; site plugins</a></li>
                <li><a href="/images/ultra_zoom_screen_4.png" target="_blank" rel="noopener">Screenshot &mdash; account &amp; Pro</a></li>
                <li><a href="/images/ultra-zoom-google-example.gif" target="_blank" rel="noopener">Animated demo &mdash; Google Images hover-zoom</a></li>
            </ul>
        </section>

        <section class="help-section" id="contact">
            <h2>Press contact</h2>
            <p>
                David McHale, Founder, Lost Rabbit Digital LLC<br>
                <a href="mailto:boden@lostrabbitdigital.com">boden@lostrabbitdigital.com</a><br>
                <a href="https://ultrazoom.app">https://ultrazoom.app</a>
            </p>
        </section>
    </main>
</BaseLayout>
