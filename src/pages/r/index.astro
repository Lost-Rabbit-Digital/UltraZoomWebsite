---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="You've been invited to Ultra Zoom"
  description="A friend thinks you'll love Ultra Zoom. Install free — and help them unlock Pro."
  noindex={true}
  og={{
    url: 'https://ultrazoom.app/r/',
    title: 'Your friend invited you to Ultra Zoom',
    description: 'Install Ultra Zoom free. You help your friend unlock Pro; they help you discover it.',
    image: 'https://ultrazoom.app/images/icon-128.png',
  }}
>
  <main class="main r-page" id="main-content">
    <section class="r-card">
      <div class="r-badge" aria-hidden="true">✓</div>
      <h1>Your friend thinks you'll love Ultra Zoom</h1>
      <p class="r-sub">
        Ultra Zoom is a free browser extension that lets you hover-zoom any image on 70+ sites. Product photos, art, collectibles, real-estate listings — details pop.
      </p>
      <p class="r-ref" id="r-ref-meta" hidden>
        Invited via code <code id="r-code-display"></code>. When you install, your friend earns credit toward Pro.
      </p>

      <div id="r-install-buttons" class="r-buttons"></div>

      <ul class="r-features">
        <li>Free forever on every site.</li>
        <li>Zero tracking, zero analytics — check the <a href="/privacy">privacy policy</a>.</li>
        <li>Works on Chrome and Firefox.</li>
      </ul>

      <p class="r-footer">
        Want your own link? <a href="/">Install Ultra Zoom</a>, then open <em>Settings → Referrals</em>.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .r-page { max-width: 580px; margin: 0 auto; padding: 48px 24px; }
  .r-card {
    background: #161b22; border: 1px solid #30363d;
    border-radius: 12px; padding: 32px; text-align: center;
  }
  .r-badge {
    width: 56px; height: 56px; border-radius: 50%;
    background: rgba(63, 185, 80, 0.15); color: #3fb950;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 28px; font-weight: 700; margin: 0 auto 16px;
  }
  .r-card h1 { margin: 0 0 12px; font-size: 24px; }
  .r-sub { color: #c9d1d9; font-size: 15px; line-height: 1.55; margin: 0 0 16px; }
  .r-ref {
    color: #8b949e; font-size: 13px; margin: 0 0 24px;
    padding: 10px 14px; background: #0d1117;
    border: 1px dashed #30363d; border-radius: 6px;
  }
  .r-ref code { font-family: monospace; color: #58a6ff; }
  .r-buttons {
    display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;
    margin: 16px 0 24px;
  }
  .r-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px; border-radius: 8px;
    font-weight: 600; font-size: 14px; text-decoration: none;
    border: 0; cursor: pointer;
  }
  .r-btn.primary { background: #58a6ff; color: #0d1117; }
  .r-btn.primary:hover { background: #79b8ff; }
  .r-btn.firefox { background: #f0883e; color: #fff; }
  .r-btn.firefox:hover { background: #ff9f4a; }
  .r-features {
    list-style: none; padding: 0; margin: 0 0 20px;
    color: #c9d1d9; font-size: 14px; line-height: 1.9;
    text-align: left; display: inline-block;
  }
  .r-features li::before { content: '\u2713  '; color: #3fb950; }
  .r-footer { color: #6e7681; font-size: 13px; margin: 0; }
  .r-footer a { color: #58a6ff; }
</style>

<script is:inline>
  (function () {
    var CODE_RE = /^[0-9a-hjkmnp-tv-z]{8}$/i;

    function escape(s) {
      return String(s ?? '').replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    function getCode() {
      var params = new URLSearchParams(location.search);
      var q = params.get('code');
      if (q && CODE_RE.test(q)) return q.toLowerCase();
      var m = location.pathname.match(/\/r\/([0-9a-hjkmnp-tv-z]{8})/i);
      return m ? m[1].toLowerCase() : null;
    }

    function setCookie(name, value, days) {
      var expires = new Date(Date.now() + days * 864e5).toUTCString();
      document.cookie = name + '=' + encodeURIComponent(value) +
        '; expires=' + expires +
        '; path=/; SameSite=Lax; Secure';
    }

    function installButtons(code) {
      var q = '?src=referral' + (code ? '&code=' + encodeURIComponent(code) : '');
      var cws = 'https://chromewebstore.google.com/detail/ultra-zoom/jalclpdejbeamaamcpbolkclpnleagmg' + q;
      var amo = 'https://addons.mozilla.org/en-US/firefox/addon/ultra-zoom/' + q;
      var isFirefox = /firefox/i.test(navigator.userAgent);
      var chrome = '<a class="r-btn primary" href="' + cws + '" target="_blank" rel="noopener">Install for Chrome</a>';
      var firefox = '<a class="r-btn firefox" href="' + amo + '" target="_blank" rel="noopener">Install for Firefox</a>';
      return isFirefox ? firefox + chrome : chrome + firefox;
    }

    var code = getCode();
    var buttonsEl = document.getElementById('r-install-buttons');
    var refMetaEl = document.getElementById('r-ref-meta');
    var codeEl = document.getElementById('r-code-display');

    if (code) {
      setCookie('uz_src', JSON.stringify({ src: 'referral', code: code }), 90);
      if (refMetaEl && codeEl) {
        codeEl.textContent = code;
        refMetaEl.hidden = false;
      }
    }

    if (buttonsEl) buttonsEl.innerHTML = installButtons(code || '');
  })();
</script>
