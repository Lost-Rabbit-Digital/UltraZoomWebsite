---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Pricing | Ultra Zoom"
  description="Ultra Zoom Pro pricing: monthly, annual, and lifetime plans. The free tier covers hover-to-zoom, theater mode, gallery navigation, and reverse image search on every site."
  currentPage="pricing"
  og={{
    url: 'https://ultrazoom.app/pricing',
    title: 'Pricing | Ultra Zoom',
    description: 'Ultra Zoom is free on every site, with theater mode, gallery navigation, and reverse image search included. Upgrade to Pro for video controls, advanced gallery, EXIF, and premium plugins.',
    image: 'https://ultrazoom.app/images/icon-128.png',
  }}
>
    <main class="main page-content" id="main-content">
        <h1>Pricing</h1>

        <p class="pricing-intro">Ultra Zoom is free to use on every site. The free tier includes hover-to-zoom, theater mode, gallery navigation, reverse image search, and 50-item hover history. Upgrade to Pro for video playback controls, advanced gallery tools, EXIF metadata, and premium plugins for sites like Instagram and YouTube.</p>

        <section class="pricing-plans" aria-label="Pricing plans">
            <article class="pricing-card">
                <h2 class="pricing-card-name">Monthly</h2>
                <p class="pricing-card-price"><strong>$3.99</strong><span class="pricing-card-per">/mo</span></p>
                <p class="pricing-card-note">7-day free trial</p>
                <button type="button" class="pricing-card-cta" data-plan="monthly">Start free trial</button>
            </article>

            <article class="pricing-card">
                <h2 class="pricing-card-name">Annual</h2>
                <p class="pricing-card-price"><strong>$29.99</strong><span class="pricing-card-per">/yr</span></p>
                <p class="pricing-card-note">7-day trial &middot; save $17.89/yr</p>
                <button type="button" class="pricing-card-cta" data-plan="annual">Start free trial</button>
            </article>

            <article class="pricing-card pricing-card--featured">
                <span class="pricing-card-badge">Best value</span>
                <h2 class="pricing-card-name">Lifetime</h2>
                <p class="pricing-card-price"><strong>$59.99</strong><span class="pricing-card-per">one-time</span></p>
                <p class="pricing-card-note">7-day trial &middot; pay once, keep forever</p>
                <button type="button" class="pricing-card-cta" data-plan="lifetime">Start free trial</button>
            </article>
        </section>

        <p id="checkout-error" class="checkout-error" hidden></p>

        <section class="why-pro" aria-label="Why upgrade to Pro">
            <h2>Why upgrade to Pro?</h2>
            <p>Pro is built for people who live in their browser. If you&rsquo;re a researcher, buyer, designer, or collector who opens a hundred tabs a day, these features pay for themselves fast.</p>
            <ul class="why-pro-list">
                <li><strong>Power shoppers</strong> use Pro to inspect thousands of <a href="/blog/online-shopping-product-photo-zoom">Amazon, Etsy, and eBay product photos</a> at full resolution without opening every listing.</li>
                <li><strong>Collectors and auction bidders</strong> rely on Pro to triage <a href="/blog/collector-auction-photo-zoom">eBay, Heritage, and Catawiki lots</a> before placing a bid &mdash; with EXIF metadata and the filmstrip view to compare angles.</li>
                <li><strong>Designers and art directors</strong> scan <a href="/blog/designer-moodboard-hover-zoom">Pinterest, Behance, and Dribbble</a> faster, with batch download, color palette extraction, and caption overlays.</li>
                <li><strong>Genealogy researchers</strong> read handwritten <a href="/blog/genealogy-archive-photo-zoom">census pages and archive scans</a> with the slideshow view and full-image download for offline annotation.</li>
            </ul>
        </section>

        <h2>Free vs. Pro</h2>

        <div class="pricing-compare-wrap">
            <table class="pricing-compare">
                <thead>
                    <tr>
                        <th scope="col">Feature</th>
                        <th scope="col">Free</th>
                        <th scope="col">Pro</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th scope="row">Hover-to-zoom on every site</th>
                        <td aria-label="Included">&#10003;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">30+ site-specific &amp; universal CDN plugins</th>
                        <td aria-label="Included">&#10003;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Community URL-rules pack (auto-updated)</th>
                        <td aria-label="Included">&#10003;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Theater / fullscreen mode</th>
                        <td aria-label="Included">&#10003;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Gallery navigation (arrow keys)</th>
                        <td aria-label="Included">&#10003;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Reverse image search (Google Lens, TinEye, Yandex, Bing)</th>
                        <td aria-label="Included">&#10003;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Hover history</th>
                        <td aria-label="Included">50 items</td>
                        <td aria-label="Included">1,000 items, searchable</td>
                    </tr>
                    <tr>
                        <th scope="row">Keyboard shortcut help (<kbd>?</kbd>)</th>
                        <td aria-label="Included">&#10003;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Audio file detection</th>
                        <td aria-label="Included">&#10003;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Premium plugins (Instagram, YouTube, TikTok, Pixiv, DeviantArt, Flickr, Facebook, LinkedIn, eBay, Steam, Twitch, VK)</th>
                        <td aria-label="Not included">&ndash;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Video preview with playback controls (play/pause, scrub, speed)</th>
                        <td aria-label="Not included">&ndash;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Advanced gallery: filmstrip, slideshow, batch download</th>
                        <td aria-label="Not included">&ndash;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">EXIF / metadata viewer</th>
                        <td aria-label="Not included">&ndash;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Color palette extraction</th>
                        <td aria-label="Not included">&ndash;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Caption overlay (titles, descriptions, alt text)</th>
                        <td aria-label="Not included">&ndash;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Custom &amp; extended URL rules</th>
                        <td aria-label="Not included">&ndash;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                    <tr>
                        <th scope="row">Settings sync across devices</th>
                        <td aria-label="Not included">&ndash;</td>
                        <td aria-label="Included">&#10003;</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <h2>Questions?</h2>
        <p>Visit the <a href="/help">Help page</a> for setup and supported sites, see how Ultra Zoom <a href="/compare/hover-zoom-plus">compares to Hover Zoom+</a> and <a href="/compare/imagus">to Imagus</a>, or review our <a href="/privacy">Privacy policy</a>. Already Pro? Manage billing on your <a href="/account">Account</a> page.</p>
    </main>

    <script is:inline>
        (function () {
            var errEl = document.getElementById('checkout-error');
            var PLAN_PRICES = { monthly: 3.99, annual: 29.99, lifetime: 59.99 };

            document.querySelectorAll('[data-plan]').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    var plan = btn.getAttribute('data-plan');
                    var value = PLAN_PRICES[plan];

                    try {
                        sessionStorage.setItem('uz_last_plan', plan);
                        if (value) sessionStorage.setItem('uz_last_plan_value', String(value));
                    } catch (_) {}

                    if (window.rdt) {
                        window.rdt('track', 'AddToCart', {
                            currency: 'USD',
                            itemCount: 1,
                            value: value,
                            products: [{ id: plan, name: 'Ultra Zoom Pro ' + plan, category: 'subscription' }]
                        });
                    }

                    if (errEl) { errEl.hidden = true; errEl.textContent = ''; }
                    btn.style.opacity = '0.6';
                    btn.style.pointerEvents = 'none';

                    fetch('https://api.ultrazoom.app/api/checkout', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ plan: plan })
                    })
                    .then(function (res) { return res.json(); })
                    .then(function (data) {
                        if (data.url) {
                            window.location.href = data.url;
                        } else {
                            throw new Error(data.error || 'Unable to start checkout');
                        }
                    })
                    .catch(function (err) {
                        if (errEl) {
                            errEl.textContent = err.message || 'Something went wrong. Please try again.';
                            errEl.hidden = false;
                        }
                    })
                    .finally(function () {
                        btn.style.opacity = '';
                        btn.style.pointerEvents = '';
                    });
                });
            });
        })();
    </script>
</BaseLayout>
