---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ultrazoom.app/' },
    { '@type': 'ListItem', position: 2, name: 'Compare', item: 'https://ultrazoom.app/compare' },
    { '@type': 'ListItem', position: 3, name: 'Ultra Zoom vs. Mage', item: 'https://ultrazoom.app/compare/mage' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Mage?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Mage is one of the many Hover Zoom forks that appeared after the original Hover Zoom privacy scandal. Like most of those forks, it carries the legacy hover-zoom workflow but ships infrequently and has limited Manifest V3 support.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is Ultra Zoom a Mage replacement?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Ultra Zoom matches the Mage workflow — instant hover preview, gallery navigation, full-resolution previews — and adds active development, native Manifest V3 builds, on-device AI upscaling, and zero telemetry.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why pick Ultra Zoom over a Hover Zoom fork?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A real company behind it (Lost Rabbit Digital LLC), a transparent Stripe-managed Pro tier, regular releases, and a zero-knowledge architecture you can verify in the build artifacts — instead of trusting a single-author fork to stay maintained and trustworthy.',
      },
    },
  ],
};
---

<BaseLayout
  title="Ultra Zoom vs. Mage — A Modern Hover Zoom Fork Alternative"
  description="Mage is a Hover Zoom fork. Ultra Zoom is the actively maintained, MV3-native, zero-telemetry alternative for Chrome and Firefox with the workflow you already know."
  currentPage="compare"
  og={{
    url: 'https://ultrazoom.app/compare/mage',
    title: 'Ultra Zoom vs. Mage',
    description: 'A privacy-first, actively maintained alternative to the Mage Hover Zoom fork.',
    image: 'https://ultrazoom.app/og/compare-mage.png',
    imageWidth: 1200,
    imageHeight: 630,
  }}
  jsonLd={[breadcrumbSchema, faqSchema]}
>
    <main class="main page-content" id="main-content">
        <h1>Ultra Zoom vs. Mage</h1>

        <p class="pricing-intro">Mage is one of many Hover Zoom forks that picked up users after <a href="/blog/hover-zoom-privacy-scandal">the original Hover Zoom privacy scandal</a>. The fork tree is messy, releases are sporadic, and Manifest V3 is putting pressure on every legacy hover-zoom extension. Ultra Zoom is the modern alternative: same workflow, current platform, real company behind it.</p>

        <section class="help-section" id="why-switch">
            <h2>Why people are switching</h2>
            <ul class="help-list">
                <li><strong>Active development.</strong> Releases every few weeks with new site plugins &mdash; not the long silences typical of single-author forks.</li>
                <li><strong>Manifest V3 native.</strong> Built for the current Chrome extension platform <a href="/blog/manifest-v3-trap">without the V3 trap</a>.</li>
                <li><strong>Zero telemetry by design.</strong> No analytics endpoint, no remote code, no server that sees your browsing. <a href="/blog/zero-knowledge-architecture">Read the architecture</a>.</li>
                <li><strong>Real Pro tier.</strong> Power features (AI upscaling, video controls, advanced gallery, hover history search) under a transparent Stripe-managed plan with a 7-day free trial.</li>
            </ul>
        </section>

        <section class="help-section" id="feature-parity">
            <h2>Feature parity at a glance</h2>
            <div class="pricing-compare-wrap">
                <table class="pricing-compare">
                    <thead>
                        <tr>
                            <th scope="col">Feature</th>
                            <th scope="col">Mage</th>
                            <th scope="col">Ultra Zoom</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <th scope="row">Hover-to-zoom on every site</th>
                            <td aria-label="Included">&#10003;</td>
                            <td aria-label="Included">&#10003;</td>
                        </tr>
                        <tr>
                            <th scope="row">Site-specific plugins</th>
                            <td aria-label="Partial">Partial</td>
                            <td aria-label="Included">&#10003;</td>
                        </tr>
                        <tr>
                            <th scope="row">Theater mode (Z)</th>
                            <td aria-label="Not included">&ndash;</td>
                            <td aria-label="Included">&#10003;</td>
                        </tr>
                        <tr>
                            <th scope="row">Reverse image search shortcuts</th>
                            <td aria-label="Not included">&ndash;</td>
                            <td aria-label="Included">&#10003;</td>
                        </tr>
                        <tr>
                            <th scope="row">On-device AI upscaling</th>
                            <td aria-label="Not included">&ndash;</td>
                            <td aria-label="Included">&#10003; (Pro)</td>
                        </tr>
                        <tr>
                            <th scope="row">Video preview &amp; playback controls</th>
                            <td aria-label="Not included">&ndash;</td>
                            <td aria-label="Included">&#10003; (Pro)</td>
                        </tr>
                        <tr>
                            <th scope="row">Hover history</th>
                            <td aria-label="Not included">&ndash;</td>
                            <td>50 free / 1,000 + search (Pro)</td>
                        </tr>
                        <tr>
                            <th scope="row">Manifest V3 native</th>
                            <td aria-label="Partial">Partial</td>
                            <td aria-label="Included">&#10003;</td>
                        </tr>
                        <tr>
                            <th scope="row">Active release cadence</th>
                            <td aria-label="Not active">Sporadic</td>
                            <td aria-label="Included">Every few weeks</td>
                        </tr>
                        <tr>
                            <th scope="row">Zero telemetry guarantee</th>
                            <td aria-label="Unclear">Unclear</td>
                            <td aria-label="Included">&#10003;</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="help-section" id="cta">
            <h2>Try it free</h2>
            <p>The core extension is free forever, with the entire site catalogue. Pro is a 7-day free trial when you&rsquo;re ready &mdash; <a href="/pricing">see plans</a>.</p>
            <ul class="install-links">
                <li>
                    <a href="https://chromewebstore.google.com/detail/ultra-zoom/jalclpdejbeamaamcpbolkclpnleagmg" class="install-button chrome" target="_blank" rel="noopener">Install for Chrome</a>
                </li>
                <li>
                    <a href="https://addons.mozilla.org/en-US/firefox/addon/ultra-zoom/" class="install-button firefox" target="_blank" rel="noopener">Install for Firefox</a>
                </li>
            </ul>
        </section>
    </main>
</BaseLayout>
