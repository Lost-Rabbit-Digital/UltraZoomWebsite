---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout
  title="Blog — Ultra Zoom"
  description="Ultra Zoom blog — updates, release notes, and tips for the hover-to-zoom browser extension."
  currentPage="blog"
>
    <main class="main page-content" id="main-content">
        <header class="blog-header">
            <h1>Ultra Zoom Blog</h1>
            <p>Release notes, tips, and stories from the people building Ultra Zoom.</p>
        </header>

        <section class="blog-list" aria-label="Blog posts">
            {posts.map(post => {
                const formattedDate = post.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                });
                const isoDate = post.data.date.toISOString().slice(0, 10);

                return (
                    <article class="blog-post">
                        <header class="blog-post-header">
                            <p class="blog-meta">
                                <time datetime={isoDate}>{formattedDate}</time>
                                <span class="blog-dot" aria-hidden="true">&bull;</span>
                                <span>{post.data.category}</span>
                            </p>
                            <h2 class="blog-post-title">
                                <a href={`/blog/${post.id}`}>{post.data.title}</a>
                            </h2>
                        </header>
                        <div class="blog-post-body">
                            <p>{post.data.description}</p>
                        </div>
                    </article>
                );
            })}
        </section>
    </main>
</BaseLayout>
