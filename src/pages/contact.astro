---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Ultra Zoom"
  description="Get help, report bugs, or request new features for Ultra Zoom."
  currentPage="contact"
  og={{
    url: 'https://ultrazoom.app/contact',
    title: 'Contact | Ultra Zoom',
    description: 'Get help, report bugs, or request new site support for the Ultra Zoom browser extension.',
    image: 'https://ultrazoom.app/images/icon-128.png',
  }}
>
    <main class="main page-content" id="main-content">
        <h1>Contact Us</h1>
        <p>Have a question, found a bug, or want to request a new feature? Fill out the form below and we'll get back to you.</p>

        <form
            id="contact-form"
            class="contact-form"
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            novalidate
        >
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off">
            <input type="hidden" name="_replyto" id="hidden-replyto">

            <div class="form-group">
                <label for="name">Name <span class="form-required" aria-hidden="true">*</span></label>
                <input
                    type="text"
                    id="name"
                    name="name"
                    autocomplete="name"
                    required
                    placeholder="Your name"
                >
            </div>

            <div class="form-group">
                <label for="email">Email <span class="form-required" aria-hidden="true">*</span></label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    autocomplete="email"
                    required
                    placeholder="you@example.com"
                >
            </div>

            <div class="form-group">
                <label for="subject">Subject <span class="form-required" aria-hidden="true">*</span></label>
                <select id="subject" name="subject" required>
                    <option value="" disabled selected>Select a topic…</option>
                    <option value="Bug Report">Bug report</option>
                    <option value="Feature Request">Feature request</option>
                    <option value="Site Request">Request support for a new website</option>
                    <option value="Pro / Billing">Pro subscription or billing</option>
                    <option value="General Question">General question</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div class="form-group">
                <label for="message">Message <span class="form-required" aria-hidden="true">*</span></label>
                <textarea
                    id="message"
                    name="message"
                    rows="6"
                    required
                    placeholder="Describe your issue or question in as much detail as you can…"
                ></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="submit-btn" id="submit-btn">Send Message</button>
                <p class="form-privacy-note">
                    Your message is sent securely via <a href="https://formspree.io" target="_blank" rel="noopener">Formspree</a>.
                    We never share your information.
                </p>
            </div>

            <div class="form-status" id="form-status" aria-live="polite" hidden></div>
        </form>

        <div class="contact-alt">
            <h2>Other Ways to Reach Us</h2>
            <p>You can also email us directly at <a href="mailto:boden@lostrabbitdigital.com">boden@lostrabbitdigital.com</a>. We aim to respond within 2 business days.</p>
        </div>
    </main>

    <script is:inline>
        (function () {
            var form = document.getElementById('contact-form');
            var status = document.getElementById('form-status');
            var btn = document.getElementById('submit-btn');
            var emailInput = document.getElementById('email');
            var replyTo = document.getElementById('hidden-replyto');

            emailInput.addEventListener('input', function() {
                replyTo.value = this.value;
            });

            form.addEventListener('submit', function (e) {
                e.preventDefault();

                if (!form.checkValidity()) {
                    form.reportValidity();
                    return;
                }

                btn.disabled = true;
                btn.textContent = 'Sending…';

                var data = new FormData(form);

                fetch(form.action, {
                    method: 'POST',
                    body: data,
                    headers: { 'Accept': 'application/json' }
                })
                .then(function (response) {
                    if (response.ok) {
                        if (window.rdt) {
                            window.rdt('track', 'Lead', {
                                conversionId: 'contact-' + Date.now()
                            });
                        }
                        form.reset();
                        showStatus('success', 'Message sent! We\'ll get back to you soon.');
                    } else {
                        return response.json().then(function (json) {
                            var msg = (json.errors && json.errors.map(function (e) { return e.message; }).join(', ')) || 'Something went wrong. Please try again.';
                            showStatus('error', msg);
                        });
                    }
                })
                .catch(function () {
                    showStatus('error', 'Network error. Please check your connection and try again.');
                })
                .finally(function () {
                    btn.disabled = false;
                    btn.textContent = 'Send Message';
                });
            });

            function showStatus(type, message) {
                status.hidden = false;
                status.className = 'form-status form-status--' + type;
                status.textContent = message;
                status.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        })();
    </script>
</BaseLayout>
