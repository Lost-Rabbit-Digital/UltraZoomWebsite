---
interface Props {
  title: string;
  description?: string;
  og?: {
    type?: string;
    url?: string;
    title?: string;
    description?: string;
    image?: string;
    imageWidth?: number;
    imageHeight?: number;
    publishedTime?: string;
    modifiedTime?: string;
    section?: string;
  };
  canonical?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  currentPage?: string;
  mainClass?: string;
  mainId?: string;
}

const {
  title,
  description,
  og,
  canonical,
  jsonLd,
  noindex = false,
  currentPage,
  mainClass = 'main',
  mainId = 'main-content',
} = Astro.props;

let canonicalPath = Astro.url.pathname;
if (canonicalPath.endsWith('/index.html')) {
  canonicalPath = canonicalPath.slice(0, -'/index.html'.length) || '/';
} else if (canonicalPath.endsWith('.html')) {
  canonicalPath = canonicalPath.slice(0, -'.html'.length);
}
const canonicalUrl = canonical ?? new URL(canonicalPath, Astro.site).toString();
const ogType = og?.type ?? 'website';
const ogImageWidth = og?.imageWidth;
const ogImageHeight = og?.imageHeight;
const twitterCard = og?.image ? 'summary_large_image' : 'summary';
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const navLinks = [
  { href: '/help', text: 'Help', page: 'help' },
  { href: '/blog', text: 'Blog', page: 'blog' },
  { href: '/pricing', text: 'Pricing', page: 'pricing' },
  { href: '/terms', text: 'Terms of Use', page: 'terms' },
  { href: '/privacy', text: 'Privacy', page: 'privacy' },
  { href: '/contact', text: 'Contact', page: 'contact' },
];

const footerLinks = [
  { href: '/help', text: 'Help' },
  { href: '/sites', text: 'Sites' },
  { href: '/blog', text: 'Blog' },
  { href: '/whats-new', text: "What's new" },
  { href: '/pricing', text: 'Pricing' },
  { href: '/account', text: 'Account' },
  { href: '/rss.xml', text: 'RSS' },
  { href: '/terms', text: 'Terms' },
  { href: '/privacy', text: 'Privacy' },
  { href: '/contact', text: 'Contact' },
  { href: '/press', text: 'Press' },
  { href: 'https://bsky.app/profile/bodengamedev.bsky.social', text: 'Bluesky', external: true },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {description && <meta name="description" content={description}>}
    <meta name="theme-color" content="#0d1117">
    {noindex && <meta name="robots" content="noindex">}
    {!noindex && <link rel="canonical" href={canonicalUrl}>}
    {og && (
        <>
            <meta property="og:type" content={ogType}>
            <meta property="og:site_name" content="Ultra Zoom">
            <meta property="og:locale" content="en_US">
            {og.url && <meta property="og:url" content={og.url}>}
            {og.title && <meta property="og:title" content={og.title}>}
            {og.description && <meta property="og:description" content={og.description}>}
            {og.image && <meta property="og:image" content={og.image}>}
            {og.image && ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)}>}
            {og.image && ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)}>}
            {og.publishedTime && <meta property="article:published_time" content={og.publishedTime}>}
            {og.modifiedTime && <meta property="article:modified_time" content={og.modifiedTime}>}
            {og.section && <meta property="article:section" content={og.section}>}
            <meta name="twitter:card" content={twitterCard}>
            {og.title && <meta name="twitter:title" content={og.title}>}
            {og.description && <meta name="twitter:description" content={og.description}>}
            {og.image && <meta name="twitter:image" content={og.image}>}
        </>
    )}
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/icon-48.png">
    <link rel="alternate" type="application/rss+xml" title="Ultra Zoom Blog" href="/rss.xml">
    <link rel="sitemap" href="/sitemap-index.xml">
    <link rel="stylesheet" href="/styles.css">
    {jsonLdBlocks.map(block => (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(block)}></script>
    ))}
    <!-- Reddit Pixel -->
    <script is:inline>
    !function(w,d){if(!w.rdt){var p=w.rdt=function(){p.sendEvent?p.sendEvent.apply(p,arguments):p.callQueue.push(arguments)};p.callQueue=[];var t=d.createElement("script");t.src="https://www.redditstatic.com/ads/pixel.js",t.async=!0;var s=d.getElementsByTagName("script")[0];s.parentNode.insertBefore(t,s)}}(window,document);rdt('init','a2_gm9ylf7cid88');rdt('track','PageVisit');
    </script>
    <!-- End Reddit Pixel -->
    <!-- Free install Lead tracking -->
    <script is:inline>
    document.addEventListener('click', function (e) {
        var el = e.target instanceof Element ? e.target.closest('.install-button') : null;
        if (!el || !window.rdt) return;
        var store = el.classList.contains('firefox') ? 'firefox' : 'chrome';
        try {
            window.rdt('track', 'Lead', {
                conversionId: 'install-' + store,
                products: [{ id: 'free-install-' + store, name: 'Ultra Zoom free install', category: 'extension' }]
            });
        } catch (_) {}
    });
    </script>
    <!-- End Free install Lead tracking --></head>
<body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="header">
        <nav class="nav" aria-label="Main navigation">
            <a href="/" class="nav-logo">
                <img src="/images/icon-48.png" alt="Ultra Zoom" width="32" height="32">
                <span>Ultra Zoom</span>
            </a>
            <div class="nav-links">
                {navLinks.map(link => (
                    <a href={link.href} {...(currentPage === link.page ? { 'aria-current': 'page' } : {})}>
                        {link.text}
                    </a>
                ))}
            </div>
        </nav>
    </header>

    <slot />

    <footer class="footer">
        <div class="footer-content">
            <div class="footer-links">
                {footerLinks.map(link => (
                    <a href={link.href} {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}>
                        {link.text}
                    </a>
                ))}
                <span class="footer-group-label">Compare</span>
                <a href="/compare">All comparisons</a>
                <a href="/compare/imagus">vs. Imagus</a>
                <a href="/compare/hover-zoom-plus">vs. Hover Zoom+</a>
                <a href="/compare/hover-zoom">vs. Hover Zoom</a>
                <a href="/compare/thumbnail-zoom-plus">vs. Thumbnail Zoom+</a>
                <a href="/compare/hover-zoom-alternatives">Best alternatives</a>
            </div>
            <p class="footer-copy">Copyright &copy; 2026 Lost Rabbit Digital, LLC. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
