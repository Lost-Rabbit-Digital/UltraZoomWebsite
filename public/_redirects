# Shareable-zoom links: rewrite /z/<id> to the /z page with ?id=<id>.
# Status 200 = rewrite (URL stays as /z/<id> for the user; content is served
# from /z — the inline script reads location.pathname to pick up the id).
/z/:id    /z?id=:id    200

# Referral links: same pattern — /r/<code> serves the /r page which
# reads the code from location.pathname.
/r/:code  /r?code=:code    200

# Zoom-score result links: /zoom-score/r/<id> rewrites to /zoom-score/r
# with ?id=<id>. The page's inline script reads either the query string
# or location.pathname to resolve the id.
/zoom-score/r/:id  /zoom-score/r?id=:id    200
